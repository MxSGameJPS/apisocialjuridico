# API
NODE_ENV=development
PORT=3333
API_SECRET_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# DataJud / CNJ
DATAJUD_BASE_URL=https://api-publica.datajud.cnj.jus.br
DATAJUD_API_KEY=

# DJEN
DJEN_BASE_URL=https://comunicaapi.pje.jus.br/api/v1/comunicacao
DJEN_API_KEY=
DJEN_ITENS_POR_PAGINA=50
DJEN_DIAS_RETROATIVOS=7
DJEN_MONITORING_ENABLED=false
DJEN_MONITORING_CRON="0 */6 * * *"

# IA / Resumos
# Use "none" para bloquear qualquer chamada de IA.
# Use "gemini" para o paliativo atual.
# Use "openai" somente se houver uma chave segura e aprovada.
AI_PROVIDER=none
AI_SUMMARY_ENABLED_DEFAULT=false
AI_SUMMARY_MAX_PER_MINUTE=10

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# OpenAI legado / opcional
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# CORS
CORS_ORIGIN=http://localhost:3000

# Monitoramento DataJud
# Mantenha false por padrão. Ative conscientemente em produção.
PROCESS_MONITORING_ENABLED=false
PROCESS_MONITORING_CRON="0 3 * * *"
